# PaddleOCR-VL 企业级API服务配置
# 复制此文件为 .env 并修改配置
# cp .env.example .env

# 服务端口
PORT=8086

# 服务主机 (0.0.0.0 表示监听所有网络接口)
HOST=0.0.0.0

# API Key 鉴权 (多个key用逗号分隔)
# ⚠️ 生产环境请替换为强密码！
API_KEYS=your-api-key-here,your-dev-key-here

# 模型配置
# 设备: gpu / cpu
DEVICE=gpu
# GPU设备ID
DEVICE_ID=0

# 是否启用文档方向分类 (True/False)
USE_DOC_ORIENTATION_CLASSIFY=True

# 是否启用文档矫正 (True/False)
USE_DOC_UNWARPING=False

# 最大并发请求数
MAX_CONCURRENT=4

# 请求超时时间(秒)
REQUEST_TIMEOUT=300

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# PDF 分页处理：每批处理页数（-1 表示不分批整份处理）
PDF_PAGE_SIZE=20

# PDF 渲染 DPI（越高越清晰，但 image_max_pixels 会限制上限）
PDF_DPI_DEFAULT=200                    # 普通页面渲染 DPI
PDF_DPI_TABLE=300                      # 表格页面渲染 DPI（裁剪放大后送表格引擎）

# VLM 后端配置（llamacpp | native | fastdeploy）
VLM_BACKEND=llamacpp

# llama.cpp 服务地址（本地开发时使用 localhost）
LLAMACPP_URL=http://localhost:8118

# 模型路由配置
ROUTING_ENABLED=True
# 复杂区域面积占比阈值（超过此比例判定为复杂页）
ROUTING_COMPLEX_THRESHOLD=0.3
# Layout检测置信度阈值
LAYOUT_CONFIDENCE_THRESHOLD=0.3
